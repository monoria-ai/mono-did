{
  "name": "mono-did",
  "private": true,
  "version": "0.1.0",
  "description": "DID and transport-agnostic handshake/protocol packages extracted from Monoclaw",
  "license": "MIT",
  "packageManager": "pnpm@10.29.2",
  "scripts": {
    "build": "pnpm -r build",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && pnpm test && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@types/node": "^25.3.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
